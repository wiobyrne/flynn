# Copy this file to .env and fill in your values

# Required — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Required — your personal Telegram chat ID
# Send /start to your bot, then visit:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# Look for "chat": {"id": 123456789}
TELEGRAM_CHAT_ID=

# Optional — only needed if Ollama is unavailable
# Uses claude-haiku (cheapest model) for routing only
ANTHROPIC_API_KEY=

# Optional — shared secret for the local agent API (port 8765)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(24))"
FLYNN_API_SECRET=
